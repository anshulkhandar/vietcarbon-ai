# ============================================
# VietCarbon AI — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ------- MongoDB Atlas -------
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/vietcarbon_ai?retryWrites=true&w=majority

# ------- Authentication -------
JWT_SECRET=change_this_to_a_strong_random_secret

# ------- AI Engine (Groq — powers FRIDAY AI) -------
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ------- Google Gemini (powers Traffic Intelligence AI reasoning) -------
# Get at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ------- ElevenLabs Voice for FRIDAY (optional) -------
# Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# ------- External API Integrations -------
# OpenRouter (optional — alternative AI fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenWeatherMap (optional — weather enrichment)
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# TomTom (powers Traffic Intelligence live flow + reverse geocoding)
# Get a free key at https://developer.tomtom.com
TOMTOM_API_KEY=your_tomtom_api_key_here

# ------- Gmail SMTP (email automation & citizen OTP) -------
# Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_digit_app_password

# ------- SMTP (citizen OTP & report emails) -------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_digit_app_password
SMTP_FROM=your_gmail@gmail.com

# ------- Server -------
PORT=5000
FRONTEND_URL=http://localhost:3000
